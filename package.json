{
  "name": "vdo-samurai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env SIMULATE_MEDIA=true INSTANCE_ID=host electron-vite dev",
    "dev:server": "vite",
    "dev:electron": "electron-vite build && NODE_ENV=development electron .",
    "dev:win": "./scripts/dev-win-electron.sh",
    "dev:dual": "node scripts/dev-dual.js",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.config.web.ts",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config vite.config.web.ts",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"*.{json,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"*.{json,js,ts}\"",
    "tsc": "tsc --noEmit",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headless": "cross-env HEADLESS=true playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "generate:test-videos": "node e2e/scripts/generate-mock-videos.js",
    "generate:sprite": "node scripts/generate-samurai-sprite.js",
    "postinstall": "node scripts/download-ffmpeg-binaries.js",
    "download:ffmpeg": "node scripts/download-ffmpeg-binaries.js",
    "download:ffmpeg:force": "node scripts/download-ffmpeg-binaries.js --force"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "trystero": "^0.23.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@napi-rs/canvas": "^0.1.89",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "electron": "^40.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "optionalDependencies": {
    "@ffprobe-installer/darwin-arm64": "^5.1.0",
    "@ffprobe-installer/darwin-x64": "^5.1.0",
    "@ffprobe-installer/linux-x64": "^5.1.0",
    "@ffprobe-installer/win32-x64": "^5.1.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.60.1"
  }
}
